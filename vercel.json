{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.go"
    },
    {
      "source": "/ws",
      "destination": "/api/index.go"
    },
    {
      "source": "/static/(.*)",
      "destination": "/web/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/web/static/$1"
    }
  ]
}